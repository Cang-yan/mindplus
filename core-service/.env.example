# ── 本地端口/主机（简化版） ──────────────────────────────────────────────────
# 前后端统一后端端口（Fastify API + Vite dev upstream）
VITE_BACKEND_PORT=3001
# 前后端统一后端主机（Vue 前后端服务统一运行时一般为 127.0.0.1）
VITE_BACKEND_HOST=127.0.0.1
# Vite 前端开发服务端口
VITE_DEV_SERVER_PORT=5173
# 显式开启 Vite 代理（可选）
VITE_DEV_FORCE_PROXY=false

# ── AI 大模型 API 密钥 ──────────────────────────────────────────────────────
VITE_OPENAI_API_KEY=
VITE_CLAUDE_API_KEY=
VITE_GEMINI_API_KEY=
VITE_GROK_API_KEY=

# ── AI 大模型 Base URL（使用中转/代理服务时填写，留空则使用各厂商官方地址）──
#
# 如果你的中转服务对所有厂商使用同一个地址（OpenAI 兼容格式），
# 则可以只填需要中转的那几个，其余留空走官方地址。
#
# 示例（将 DeepSeek 请求转发到本地代理）：
#   VITE_DEEPSEEK_BASE_URL=https://relay.example.com/v1
#
VITE_OPENAI_BASE_URL=
VITE_CLAUDE_BASE_URL=
VITE_GEMINI_BASE_URL=
VITE_GROK_BASE_URL=
VITE_CUSTOM_BASE_URL=

# ── 主项目 AiPPT 接口配置（工作流页面使用）────────────────────────────────
# 这是 AiPPT（PPT 生成）通道专用 key。
# 示例：
#   VITE_PPT_BASE_URL=https://api.linkapi.org
#   VITE_PPT_API_KEY=sk-xxxx
#   一般不需要更改
#   VITE_PPT_API_PREFIX=/docmee/v1/api/ppt
#   VITE_PPT_JSON_API_PREFIX=/docmee/v1/api/pptjson
VITE_PPT_BASE_URL=
VITE_PPT_API_KEY=
VITE_PPT_API_PREFIX=/docmee/v1/api/ppt
VITE_PPT_JSON_API_PREFIX=/docmee/v1/api/pptjson

# ── Assistant / OCR / 文献翻译通道 ───────────────────────────────────────────
# 后端默认复用 VITE_OPENAI_BASE_URL（未配置时回退 https://api.openai.com/v1）。
ASSISTANT_AI_KEY=
OCR_AI_KEY=
#翻译
VITE_FY_BASE_URL=
VITE_FY_API_KEY=
VITE_FY_MODEL=gpt-4o-mini

# ── MindUser 统一会员系统 ────────────────────────────────────────────────────
# 统一登录中心地址（用于 /login 跳转与个人中心跳转）
VITE_MINDUSER_BASE_URL=http://127.0.0.1:3100
# 服务键（默认 mindplus）
VITE_MINDUSER_SERVICE_KEY=mindplus
# 用户中心跳转地址：
# 1) 可填完整 URL（如 http://127.0.0.1:3100/mindplus/app）
# 2) 也可仅填路径（如 /mindplus/app，会自动拼接到 VITE_MINDUSER_BASE_URL）
VITE_MINDUSER_PROFILE_URL=/mindplus/app

# ── Billing 扣费配置（按场景固定单价）────────────────────────────────────────
# 是否启用扣费逻辑（true/false）
BILLING_ENABLED=true
# 调用 /open/consume 与 /open/recharge 的内部密钥
# 若 MindUser 未配置 INTERNAL_RECHARGE_KEY，可留空
BILLING_INTERNAL_KEY=
# 兼容旧变量（未设置 BILLING_INTERNAL_KEY 时会读取这里）
BILLING_INTERNAL_CONSUME_KEY=
# 是否优先从钱包余额扣减（true/false）
BILLING_CONSUME_WITH_WALLET=true
# 欠费上限：<0 = 不限；0 = 不允许欠费；>0 = 允许欠费额度
BILLING_OVERDRAFT_LIMIT=-1
# 场景单价（credits）
BILLING_PRICE_AIPPT_OUTLINE=0
BILLING_PRICE_AIPPT_JSON2PPT=50
BILLING_PRICE_LITERATURE_OCR=2
BILLING_PRICE_LITERATURE_TRANSLATE=2
# 文献生成（按学术等级）
BILLING_PRICE_LITERATURE_ASSISTANT_RESEARCH=20
BILLING_PRICE_LITERATURE_ASSISTANT_BACHELOR=33
BILLING_PRICE_LITERATURE_ASSISTANT_MASTER=50
BILLING_PRICE_LITERATURE_ASSISTANT_PHD=100

# =============================================================================
# 后端（Fastify）变量（frontend/server 读取同一份根目录 .env）
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# 可选：后端监听地址（默认 0.0.0.0）
# AIPPT_BACKEND_BIND_HOST=0.0.0.0
SERVER_NODE_ENV=production
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRY=7d
MINDUSER_JWT_SECRET=change-this-secret-in-production
MINDUSER_SERVICE_KEY=mindplus

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=mindplus
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECTION_LIMIT=10
MYSQL_WAIT_FOR_CONNECTIONS=true
UPLOAD_DIR=./uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── OpenDraft 后端服务 ────────────────────────────────────────────────────────
OPENDRAFT_SERVICE_BASE_URL=http://127.0.0.1:18080
