GOOGLE_API_KEY=your_google_api_key
# Gemini SDK endpoint (supports full URL or host, e.g. https://api.linkapi.org/v1beta/models)
GEMINI_API_ENDPOINT=https://api.linkapi.org/v1beta/models
# OpenAI-compatible proxy endpoint for chapter refinement
OPENAI_BASE_URL=https://api.linkapi.org/v1
ENABLE_SEMANTIC_SCHOLAR=false
ENABLE_GEMINI_GROUNDED=false
OPENDRAFT_HOST=0.0.0.0
OPENDRAFT_PORT=18080
OPENDRAFT_DISABLE_SYSTEM_PROXY=true
# Process default timezone (used by datetime.now / logs). Default is Asia/Shanghai.
OPENDRAFT_TIMEZONE=Asia/Shanghai
# Deep research planning timeout (seconds). Default in code is 80.
DEEP_RESEARCH_PLANNING_TIMEOUT_SECONDS=80

# Unified MindPlus MySQL database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=mindplus
MYSQL_CHARSET=utf8mb4
# MySQL session timezone; defaults to +08:00 for Shanghai.
MYSQL_TIMEZONE=+08:00
